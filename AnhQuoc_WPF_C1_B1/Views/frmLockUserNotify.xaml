<Window x:Class="AnhQuoc_WPF_C1_B1.Views.frmLockUserNotify"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:AnhQuoc_WPF_C1_B1.Views"
        xmlns:local="clr-namespace:AnhQuoc_WPF_C1_B1"
        xmlns:converter="clr-namespace:AnhQuoc_WPF_C1_B1.Converters"
        mc:Ignorable="d"
        Title="frmLockUserNotify" SizeToContent="WidthAndHeight">
    <Window.Resources>
        <local:StatusToTextConverter x:Key="statusToTextConverter" />
        <converter:ImageConverter x:Key="imageConverter" />
        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="Foreground" Value="#BDBDBD"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="DataAreaStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="20"/>
            <Setter Property="Padding" Value="30"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource DataAreaStyle}">
        <StackPanel Margin="30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Source="{Binding Image, Converter={StaticResource imageConverter}}" Width="200" Height="200" Stretch="Fill" />
                <Grid Grid.Column="1" Margin="20 0 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,25">
                        <Label Content="Username" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Username}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="20,0,0,25">
                        <Label Content="Role" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Role}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,25">
                        <Label Content="Email" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Email}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="20,0,0,25">
                        <Label Content="Phone" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Phone}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,25">
                        <Label Content="Address" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Address}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="20,0,0,25">
                        <Label Content="Status" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Status, Converter={StaticResource statusToTextConverter}}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>
                </Grid>
            </Grid>
            <StackPanel Margin="0 30 0 0" Orientation="Horizontal">
                <TextBlock FontWeight="Bold" FontSize="15">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="1">
                                    <Setter Property="Text" Value="Are you sure you want to lock this user account?" />

                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="0">
                                    <Setter Property="Text" Value="Are you sure you want to unlock this user account?" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <StackPanel Margin="10 0 0 0" Orientation="Horizontal">
                    <Button Name="btnYes" Click="BtnYes_Click" Content="Yes" Margin="0 0 10 0" Style="{StaticResource YesNoButtonStyle}" />
                    <Button Name="btnNo" Click="btnNo_Click" Content="No" Style="{StaticResource YesNoButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
