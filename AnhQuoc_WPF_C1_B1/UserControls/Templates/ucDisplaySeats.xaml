<UserControl x:Class="AnhQuoc_WPF_C1_B1.UserControls.ucDisplaySeats"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnhQuoc_WPF_C1_B1.UserControls"
             xmlns:enums="clr-namespace:AnhQuoc_WPF_C1_B1.Enums"
             xmlns:converter="clr-namespace:AnhQuoc_WPF_C1_B1.Converters"
             xmlns:userControl="clr-namespace:AnhQuoc_WPF_C1_B1.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#1A1A1A">
    <UserControl.Resources>
        <ControlTemplate x:Key="btnSeatTemplate" TargetType="Button">
            <!-- The RenderTransform allows us to smoothly scale up on hover -->
            <Border x:Name="border" 
                    Background="{TemplateBinding Background}" 
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Grid>
                    <Border x:Name="InteractionOverlay" CornerRadius="6" Background="Transparent"/>
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <!-- 1. HOVER STATE: Slightly scale up and add a white tint -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="InteractionOverlay" Property="Background" Value="#15FFFFFF"/>
                    <Setter TargetName="border" Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.08" ScaleY="1.08"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <!-- 2. CLICK / PRESSED STATE: Shrink down slightly and darken -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="InteractionOverlay" Property="Background" Value="#30000000"/>
                    <Setter TargetName="border" Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>


        <!-- Seat Style using DataTriggers for dynamic colors -->
        <Style x:Key="DynamicSeatStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- The RenderTransform allows us to smoothly scale up on hover -->
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <Grid>
                                <!-- Interaction Overlay Layer -->
                                <Border x:Name="InteractionOverlay" CornerRadius="6" Background="Transparent"/>

                                <!-- Content Presenter (Text) -->
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- 1. HOVER STATE: Slightly scale up and add a white tint -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InteractionOverlay" Property="Background" Value="#15FFFFFF"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.08" ScaleY="1.08"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <!-- 2. CLICK / PRESSED STATE: Shrink down slightly and darken -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="InteractionOverlay" Property="Background" Value="#30000000"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Maintain your dynamic background color bindings -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding Type}" Value="Standard">
                    <Setter Property="Background" Value="#6A24D6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="VIP">
                    <Setter Property="Background" Value="#E5252D"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Booked">
                    <Setter Property="Background" Value="#3A3D40"/>
                    <!-- Optional: Disable hover/click interactions for already booked seats -->
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Selected">
                    <Setter Property="Background" Value="#D81B60"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="btnSeatStyle" TargetType="Button" BasedOn="{StaticResource DynamicSeatStyle}">
            <Style.Setters>
                <EventSetter Event="Click" Handler="btnSeat_Click"/>
            </Style.Setters>
        </Style>

        <Style x:Key="SelectedSeatStyle" TargetType="Button">
            <Style.Setters>
                <EventSetter Event="Click" Handler="btnSeat_Click"/>
                <Setter Property="Width" Value="36"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <!-- The RenderTransform allows us to smoothly scale up on hover -->
                            <Border x:Name="border" 
                                Background="Transparent" 
                                BorderBrush="#D81B60" BorderThickness="2" CornerRadius="4"
                                RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>

                                <Grid>
                                    <!-- Interaction Overlay Layer -->
                                    <Border x:Name="InteractionOverlay" CornerRadius="6" Background="Transparent"/>

                                    <!-- Content Presenter (Text) -->
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ControlTemplate.Triggers>
                                <!-- 1. HOVER STATE: Slightly scale up and add a white tint -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="InteractionOverlay" Property="Background" Value="#15FFFFFF"/>
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.08" ScaleY="1.08"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>

                                <!-- 2. CLICK / PRESSED STATE: Shrink down slightly and darken -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="InteractionOverlay" Property="Background" Value="#30000000"/>
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style.Setters>

            <!-- Maintain your dynamic background color bindings -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding Type}" Value="Standard">
                    <Setter Property="Background" Value="#6A24D6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="VIP">
                    <Setter Property="Background" Value="#E5252D"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Booked">
                    <Setter Property="Background" Value="#3A3D40"/>
                    <!-- Optional: Disable hover/click interactions for already booked seats -->
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Selected">
                    <Setter Property="Background" Value="#D81B60"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <converter:SeatStyleConverter x:Key="SeatStyleConverter" 
                                   DefaultStyle="{StaticResource btnSeatStyle}" 
                                   SelectedStyle="{StaticResource SelectedSeatStyle}" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Screen Title -->
                <RowDefinition Height="*"/>
                <!-- Seating Layout Box -->
                <RowDefinition Height="Auto"/>
                <!-- Bottom Legend Footer -->
            </Grid.RowDefinitions>

            <!-- SCREEN INDICATOR -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
                <Border Width="240" Height="3" Background="White"/>
                <TextBlock Text="MÀN HÌNH" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0" FontSize="12" />
            </StackPanel>

            <!-- DYNAMIC ITEMS CONTROL -->
            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- SINGLE ItemsControl handles the flat 1D collection -->
                <ItemsControl ItemsSource="{Binding Seats}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- 
                        CRITICAL UPDATE: UniformGrid automatically wraps items every 18 elements.
                        This completely replaces the old nested row/column StackPanels.
                    -->
                            <UniformGrid Columns="18" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}" Margin="4,2">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <Border Width="36" Height="36" Background="Transparent"/>
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Converter={StaticResource NullToBoolConverter}}" Value="True">
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <Button Content="{Binding Id}"
                                                                Style="{Binding Type, Converter={StaticResource SeatStyleConverter}}">
                                                            </Button>
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Vùng trung tâm Outline (Hardcoded overlay boundary matching center grid row dimensions) -->
                <!-- Fits over rows 3, 4, 5 (D, E, F) and cols 5, 6, 7, 8 -->
                <Border BorderBrush="#10B981" BorderThickness="1.5" CornerRadius="8" IsHitTestVisible="False"
                Height="132" VerticalAlignment="Top" Margin="210,112,295,0"/>
            </Grid>

            <!-- LEGEND COMPONENT FOOTER -->
            <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,30,0,10">
                <StackPanel Orientation="Horizontal" Margin="15,0">
                    <Border Width="18" Height="18" Background="#3A3D40" CornerRadius="4"/>
                    <TextBlock Text="Đã đặt" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="15,0">
                    <Border Width="18" Height="18" Background="#E5252D" CornerRadius="4"/>
                    <TextBlock Text="Ghế VIP" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="15,0">
                    <Border Width="18" Height="18" Background="Transparent" BorderBrush="#D81B60" BorderThickness="2" CornerRadius="4"/>
                    <TextBlock Text="Ghế bạn chọn" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="15,0">
                    <Border Width="18" Height="18" Background="Transparent" BorderBrush="#10B981" BorderThickness="1.5" CornerRadius="4"/>
                    <TextBlock Text="Vùng trung tâm" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="15,0">
                    <Border Width="18" Height="18" Background="#6A24D6" CornerRadius="4"/>
                    <TextBlock Text="Ghế thường" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                </StackPanel>
            </WrapPanel>
        </Grid>
        <userControl:ucTicketSummary x:Name="ucTicketSummary"
                                     Grid.Row="1"
                                     SelectedSeats="{Binding SelectedSeats}"
                                     SeatsSource="{Binding Seats}"
                                     frmBookingTicket="{Binding frmBookingTicket}"/>
    </Grid>
</UserControl>
