<UserControl x:Class="AnhQuoc_WPF_C1_B1.ucMovieTable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnhQuoc_WPF_C1_B1"
             xmlns:converter="clr-namespace:AnhQuoc_WPF_C1_B1.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <local:DateConverter x:Key="dateConverter" />
        <converter:ImageConverter x:Key="imageConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Style="{StaticResource AddButtonStyle}"
                Margin="30"
                HorizontalAlignment="Right"
                Name="btnAdd"
                Content="Add new movie"
                Click="btnAdd_Click"/>
        <DataGrid Grid.Row="1"
                  VerticalAlignment="Stretch"
                  IsReadOnly="True"
                HorizontalAlignment="Stretch"
                Name="dgTable"
                AutoGenerateColumns="False"
                Style="{StaticResource ModernDataGrid}"
                SelectedItem="{Binding CurrentItem}"
                    ScrollViewer.CanContentScroll="True">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="auto" Header="Movie">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="50" Height="50" HorizontalAlignment="Center">
                                    <Ellipse.Fill>
                                        <ImageBrush>
                                            <ImageBrush.ImageSource>
                                                <Binding Path="UrlImage" Converter="{StaticResource imageConverter}" ConverterParameter="Movies">
                                                    <!-- 3. Corrected resource paths -->
                                                    <Binding.TargetNullValue>
                                                        <BitmapImage UriSource="/Assets/unload_placeholder.png" />
                                                    </Binding.TargetNullValue>
                                                    <Binding.FallbackValue>
                                                        <BitmapImage UriSource="/Assets/unload_placeholder.png" />
                                                    </Binding.FallbackValue>
                                                </Binding>
                                            </ImageBrush.ImageSource>
                                        </ImageBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Binding="{Binding Id}" Header="Id"/>
                <DataGridTextColumn Binding="{Binding Name}" Header="Name"/>
                <DataGridTextColumn Binding="{Binding Rated.Id}" Header="Rated"/>
                <DataGridTextColumn Binding="{Binding RunningTime}" Header="Running Time"/>
                <DataGridTextColumn Width="*" Binding="{Binding ReleaseDate, Converter={StaticResource dateConverter}}" Header="ReleaseDate"/>
                <DataGridTemplateColumn Header="Operations">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Background="#dc3545" Foreground="White"
                                    Style="{StaticResource OperationButtonStyle}"
                                    Name="btnDelete"
                                    Click="btnDelete_Click">
                                    <Path Data="{StaticResource TrashIconData}"
                                        Fill="White" Stretch="Uniform"/>
                                </Button>
                                <Button Style="{StaticResource OperationButtonStyle}"
                                    Background="#28a745" Foreground="White"
                                    Name="btnUpdate"
                                    Click="btnUpdate_Click">
                                    <Path Data="{StaticResource EditIconData}"
                                        Fill="White" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
