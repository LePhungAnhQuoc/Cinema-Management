<UserControl x:Class="AnhQuoc_WPF_C1_B1.ucMovieScheduleTable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnhQuoc_WPF_C1_B1"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="500"
             Loaded="UserControl_Loaded">
    <StackPanel>
        <Button Style="{StaticResource AddButtonStyle}"
                HorizontalAlignment="Right"
                Margin="30"
                Name="btnAdd"
                Content="Add New Movie"
                Click="btnAdd_Click"/>
        <DataGrid Style="{StaticResource ModernDataGrid}"
                  IsReadOnly="True"
                  HorizontalAlignment="Stretch"
                  Name="dgTable"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Width="auto" Binding="{Binding Id}" Header="Id"/>
                <DataGridTextColumn Width="1*" Binding="{Binding Name}" Header="Name"/>
                <DataGridTextColumn Width="auto" Binding="{Binding Rated.Id}" Header="Rated"/>
                <DataGridTextColumn Width="auto" Binding="{Binding RunningTime}" Header="Running Time"/>
                <DataGridTextColumn Width="auto" Binding="{Binding ReleaseDate, StringFormat='{}{0:dd/MM/yyyy}'}" Header="ReleaseDate"/>
                <DataGridTemplateColumn Width="auto" Header="Operations">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center"
                                        Orientation="Horizontal">
                                <Button Background="#dc3545" Foreground="White"
                                        Style="{StaticResource OperationButtonStyle}"
                                        Name="btnDelete"
                                        Click="btnDelete_Click">
                                    <Path Data="{StaticResource TrashIconData}"
                                          Fill="White" Stretch="Uniform"/>
                                </Button>
                                <Button Style="{StaticResource OperationButtonStyle}"
                                        Background="#28a745" Foreground="White"
                                        Name="btnUpdate"
                                        Click="btnUpdate_Click">
                                    <Path Data="{StaticResource EditIconData}"
                                          Fill="White" Stretch="Uniform"/>
                                </Button>
                                <Button Style="{StaticResource OperationButtonStyle}"
                                        Background="#00ccff" Foreground="White"
                                        Name="btnDetail"
                                        Click="btnDetail_Click">
                                    <Path Data="{StaticResource InfoIconData}"
                                          Fill="White" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</UserControl>
