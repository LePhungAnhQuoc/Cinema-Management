<Application x:Class="AnhQuoc_WPF_C1_B1.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AnhQuoc_WPF_C1_B1"
             xmlns:xctk="clr-namespace:Xceed.Wpf.Toolkit;assembly=Xceed.Wpf.Toolkit"
             xmlns:converter="clr-namespace:AnhQuoc_WPF_C1_B1.Converters"
             xmlns:SystemWindows="clr-namespace:System.Windows;assembly=PresentationFramework"
             StartupUri="MainWindow.xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             ShutdownMode="OnLastWindowClose">
    <Application.Resources>
        <converter:ImageConverter x:Key="ImageConverter" />
        <converter:TreeViewMarginConverter x:Key="TreeViewMarginConverter" />
        <converter:ItemIndexConverter x:Key="IndexConverter" />
        <converter:NullToBoolConverter x:Key="NullToBoolConverter" />
        <syncfusion:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="accountStatusTrue" Color="Green" />
        <SolidColorBrush x:Key="accountStatusFalse" Color="Red" />
        <SolidColorBrush x:Key="TextDark" Color="#212121"/>
        <SolidColorBrush x:Key="TextMuted" Color="#757575"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="BackgroundLight" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryAccent" Color="#FF007ACC"/>

        <Style x:Key="placeholderStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" 
                                CornerRadius="12" 
                                Background="White">
                            <Grid>
                                <TextBlock x:Name="PlaceholderText"
                                           Text="{TemplateBinding Tag}" 
                                           Foreground="#C0B9B7" 
                                           FontSize="{TemplateBinding FontSize}"
                                           Padding="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>

                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseWindowStyle" TargetType="{x:Type SystemWindows:Window}">
            <Setter Property="SizeToContent" Value="Height" />
        </Style>
        
        <!-- Custom Style for the Circular Equals Button -->
        <Style x:Key="CircleEqualsButtonStyle" TargetType="ToggleButton">
            <!-- Force equal dimensions to guarantee a perfect circle -->
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <!-- CornerRadius must be exactly half of the Width/Height to make it a circle -->
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="30" 
                            BorderBrush="#E5E5E5" 
                            BorderThickness="1">

                            <!-- Drop shadow effect matching the soft look in image_a5ba3f.png -->
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" 
                                      ShadowDepth="2" 
                                      Direction="270" 
                                      Opacity="0.1"/>
                            </Border.Effect>

                            <!-- The Equals Icon Content -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <!-- Top Blue Line -->
                                <Rectangle Width="22" Height="3" Fill="#1E67D6" RadiusX="1.5" RadiusY="1.5"/>
                                <!-- Gap between lines -->
                                <Border Height="6"/>
                                <!-- Bottom Blue Line -->
                                <Rectangle Width="22" Height="3" Fill="#1E67D6" RadiusX="1.5" RadiusY="1.5"/>
                            </StackPanel>
                        </Border>

                        <!-- Hover and Click Animations -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F7F9FC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EEF2F8"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" CenterX="30" CenterY="30"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Style for the Back Arrow Navigation Button -->
        <Style x:Key="CircleBackNavigationButtonStyle" TargetType="Button">
            <!-- Exact circular proportions -->
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- The outer ring container matching image_b34322.png -->
                        <Border x:Name="outerCircle" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="#000000" 
                                BorderThickness="4" 
                                CornerRadius="32"
                                SnapsToDevicePixels="True">

                            <!-- Precise path markup representing the sharp arrow geometry -->
                            <Path x:Name="arrowIcon"
                                  Data="M 36,16 L 16,30 L 36,44 L 36,35 L 48,35 L 48,25 L 36,25 Z" 
                                  Fill="#000000" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Margin="4"/>
                        </Border>

                        <!-- Interactive Hover & Click States -->
                        <ControlTemplate.Triggers>
                            <!-- Invert colors on hover for a modern dynamic feel -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outerCircle" Property="Background" Value="#000000"/>
                                <Setter TargetName="arrowIcon" Property="Fill" Value="#FFFFFF"/>
                            </Trigger>
                            <!-- Slight press feedback effect -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="outerCircle" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94" CenterX="32" CenterY="32"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 1. Style for the Internal Spinner Columns inside the Dropdown -->
        <Style x:Key="CustomTimeSelectorStyle" TargetType="syncfusion:SfTimeSelector">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <!-- Custom data template configuration for the cell components if needed -->
            <Setter Property="HourCellTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid>
                            <TextBlock Margin="4"
                                       Text="{Binding DisplayText}" 
                                       Foreground="{StaticResource TextDark}" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 2. Main Style for the SfTimePicker Control -->
        <Style x:Key="ModernSfTimePicker" TargetType="syncfusion:SfTimePicker">
            <!-- Basic Control Layout Upgrades -->
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Padding" Value="10,6,8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <!-- Behavior settings to bypass hitting 'OK' manually to update input -->
            <Setter Property="SetValueOnLostFocus" Value="True"/>

            <!-- Link the sub-control styling options built into the component -->
            <Setter Property="SelectorStyle" Value="{StaticResource CustomTimeSelectorStyle}"/>
            <Setter Property="SelectorItemWidth" Value="55"/>
            <Setter Property="SelectorItemHeight" Value="40"/>
            <Setter Property="DropDownHeight" Value="250"/>

            <!-- Apply look and feel modifications through UI Triggers -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource TextMuted}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                </Trigger>
                <Trigger Property="IsDropDownOpen" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernRoundedTimePicker" TargetType="{x:Type xctk:TimePicker}">
            <!-- Default Properties -->
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,6,12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type xctk:TimePicker}">
                        <Grid x:Name="MainGrid" Background="Transparent">
                            <!-- Smooth Pill-shaped Container -->
                            <Border x:Name="BaseBorder"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            SnapsToDevicePixels="True">

                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Native Toolkit Watermark TextBox for smooth text input -->
                                    <TextBox x:Name="PART_TextBox"
                                     Grid.Column="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{TemplateBinding Foreground}"
                                     FontFamily="{TemplateBinding FontFamily}"
                                     FontSize="{TemplateBinding FontSize}"
                                     HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                     VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                     VerticalContentAlignment="Center"
                                     Focusable="True"/>

                                    <!-- Clean Interactive Clock Icon Toggle Button -->
                                    <ToggleButton x:Name="PART_ToggleButton"
                                          Grid.Column="1"
                                          Margin="6,0,0,0"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          Focusable="False"
                                          IsChecked="{Binding IsOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                <Grid Background="Transparent" Width="18" Height="18">
                                                    <!-- Modern minimalist clock icon geometry -->
                                                    <Path Data="M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12.5,7H11V13L16.25,16.15L17,14.92L12.5,12.25V7Z" 
                                                  Fill="#9E9E9E" 
                                                  Stretch="Uniform"
                                                  x:Name="IconPath"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource PrimaryAccent}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource PrimaryAccent}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <!-- Flat Dropdown Drop Shadow Popup -->
                                    <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   StaysOpen="False">
                                        <Border Background="#FFFFFF"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,6,0,6">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.1"/>
                                            </Border.Effect>

                                            <!-- Time Listbox Container -->
                                            <ListBox x:Name="PART_TimeListPicker" 
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Width="160"
                                             MaxHeight="220"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Modern Interaction Triggers -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BaseBorder" Property="BorderBrush" Value="#BDBDBD"/>
                                <Setter TargetName="BaseBorder" Property="Background" Value="#FAFAFA"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="BaseBorder" Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                                <Setter TargetName="BaseBorder" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                            <!-- Visual feedback when the popup dropdown is actually open -->
                            <Trigger Property="IsOpen" Value="True">
                                <Setter TargetName="BaseBorder" Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
