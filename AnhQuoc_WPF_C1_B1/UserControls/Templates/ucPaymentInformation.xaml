<local:UserControlBase x:Class="AnhQuoc_WPF_C1_B1.UserControls.Templates.ucPaymentInformation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnhQuoc_WPF_C1_B1"
             xmlns:converter="clr-namespace:AnhQuoc_WPF_C1_B1.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="1050" d:DesignWidth="1000">
    <local:UserControlBase.Resources>
        <converter:LogicalNegationConverter x:Key="LogicalNegationConverter" />
    </local:UserControlBase.Resources>
    <ScrollViewer>
        <Border Width="1000"
                Height="Auto" 
                Background="White" 
                CornerRadius="24" 
                BorderBrush="#FFEFEBE9" 
                BorderThickness="1" 
                Margin="20"
                VerticalAlignment="Center" 
                HorizontalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="25" 
                          Color="#000000" 
                          Opacity="0.06" 
                          ShadowDepth="8" 
                          Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0"
                      Name="AccountInformation">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                  Margin="20"
                  IsEnabled="{Binding IsUserLoggedIn, Converter={StaticResource LogicalNegationConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" VerticalAlignment="Top" Margin="0,4,16,0">
                            <Ellipse Width="42" Height="42" Fill="#C42E3B"/>
                            <TextBlock Text="K" 
                           Foreground="White" 
                           FontWeight="Bold" 
                           FontSize="18" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Margin="0,0,0,2"/>
                        </Grid>

                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Bottom">
                                <TextBlock Text="Người nhận vé" 
                               FontWeight="Bold" 
                               FontSize="16" 
                               Foreground="#1C1B1B"/>
                                <TextBlock Text="Khách vãng lai" 
                                           FontSize="13" 
                                           Foreground="#7D7471" 
                                           Margin="8,0,0,1" 
                                           VerticalAlignment="Bottom">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUserLoggedIn}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <TextBox Grid.Column="1" Height="48" Margin="0,0,0,12" Padding="14,0" VerticalContentAlignment="Center"
                                     Text="{Binding Account.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     Foreground="#9E9694" FontSize="15" BorderBrush="#E0D9D7"
                                     Tag="Nhập họ và tên"
                                     Style="{StaticResource placeholderStyle}">
                            </TextBox>
                            
                            <TextBox Height="48" Margin="0,0,0,12" Padding="14,0" VerticalContentAlignment="Center"
                         Text="{Binding Account.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="#9E9694" FontSize="15" BorderBrush="#E0D9D7"
                                     Tag="Nhập số điện thoại"
                                     Style="{StaticResource placeholderStyle}"/>

                            <TextBox Tag="Nhập địa chỉ email"
                                    Style="{StaticResource placeholderStyle}"
                                    Height="48" Margin="0,0,0,16" Padding="14,0" VerticalContentAlignment="Center"
                         Text="{Binding Account.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="#9E9694" FontSize="15" BorderBrush="#E0D9D7"
                                     PreviewKeyDown="TxtEmail_PreviewKeyDown"/>

                            <Button x:Name="btnSaveUserInfo"
                                    Click="BtnSaveUserInformation_Click"
                                    Content="Lưu" Height="40" Width="76" Background="#C42E3B" Foreground="White" 
                        FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Left" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#A5222E"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Separator Grid.Row="1" Background="#FFEFEBE9" Margin="0" Height="1"/>

                    <Grid 
                        Margin="20"
                        Grid.Row="2"
                        Name="SelectedPaymentMethod">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Margin="0,0,16,0" ClipToBounds="True">
                            <Image Source="/bin/Debug/Assets/Others/Payment_Methods/Payoo.jpg" Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="THANH TOÁN BẰNG" 
                           FontSize="11" 
                           FontWeight="Bold" 
                           Foreground="#7D7471" 
                           Margin="0,0,0,2"/>
                            <TextBlock Text="Thẻ ATM/Thẻ quốc tế" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#1C1B1B"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <StackPanel Name="PaymentInformation"
                            Grid.Column="1"
                            Width="450"
                            Margin="30, 30, 30, 20"
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                    <!-- SECTION 1: Movie Details -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Movie Poster with rounded corners -->
                        <Border Grid.Column="0"  Width="90" Height="120" CornerRadius="15" ClipToBounds="True">
                            <Image Source="{Binding Movie.UrlImage, Converter={StaticResource ImageConverter}, ConverterParameter='Movies'}" 
                       Stretch="UniformToFill"/>
                        </Border>

                        <!-- Text Info -->
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Foreground="#C82333" FontWeight="Bold" FontSize="14" Margin="0,0,0,4">
                                <Run Text="2D LỒNG TIẾNG · " />
                                <Run Text="{Binding Movie.Rated.Id}" />
                            </TextBlock>
                            <TextBlock Text="{Binding Movie.Name}" Foreground="#111111" FontWeight="Bold" FontSize="20" Margin="0,0,0,6"/>
                            <TextBlock Foreground="#666666" FontSize="14" Margin="0,0,0,4">
                                <Run Text="{Binding TimeSchedule.Time, StringFormat='{}{0:hh\\:mm}'}" />
                                <Run Text="{Binding DateSchedule.Date, StringFormat='{}{0:dddd}'}" />
                                <Run Text="{Binding DateSchedule.Date, StringFormat='{}{0:dd/MM}'}" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Solid Thin Separator -->
                    <Border BorderBrush="#F0F0F0" BorderThickness="0,1,0,0" Margin="0,0,0,20"/>

                    <!-- SECTION 2: Pricing Details -->
                    <StackPanel Margin="0,0,0,20">
                        <!-- Row 1: Tickets -->
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="{Binding QuantityBySeatTypesSummary}" Foreground="#555555" FontSize="16" />
                            <TextBlock Text="{Binding TotalSeatPrice, StringFormat='{}{0:N0} đ'}" Foreground="#111111" FontSize="16" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <!-- Dashed Separator -->
                    <Line X1="0" X2="390" Y1="0" Y2="0" 
              Stroke="#E0E0E0" StrokeThickness="1" 
              StrokeDashArray="4,4" 
              Margin="0,0,0,25" />

                    <!-- SECTION 3: Total -->
                    <Grid Margin="0,0,0,25" VerticalAlignment="Center">
                        <TextBlock Text="Tổng thanh toán" Foreground="#111111" FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center"/>
                        <!-- Custom underlined currency styling using Run elements -->
                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                <Run Text="{Binding TotalPrice, StringFormat='{}{0:N0}'}" Foreground="#C82333" FontWeight="Bold" FontSize="28"/>
                <Run Text="đ" Foreground="#C82333" FontWeight="Bold" FontSize="28" TextDecorations="Underline"/>
                        </TextBlock>
                    </Grid>

                    <!-- SECTION 4: Actions -->
                    <!-- Payment Button -->
                    <Button Click="BtnPayment_Click"
                            Height="60" Background="#C82333" BorderThickness="0" Cursor="Hand" Margin="0,0,0,15">
                        <Button.Resources>
                            <!-- Quick template style to get the perfect round corners for the button -->
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bdBackground" Background="{TemplateBinding Background}" CornerRadius="18">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bdBackground" Property="Background" Value="#A5222E"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="bdBackground" Property="Background" Value="#8F1A22"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Resources>

                        <StackPanel Orientation="Horizontal">
                            <!-- Lock Icon Unicode (🔓/🔒) -->
                            <TextBlock Text="🔒 " Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,2"/>
                            <TextBlock Text="Thanh toán" Foreground="White" FontWeight="Bold" FontSize="18" VerticalAlignment="Center">
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Back Link -->
                    <Button Content="← Quay lại" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Foreground="#555555" 
                            FontSize="15" 
                            HorizontalAlignment="Center"
                            Cursor="Hand"
                            Click="BtnGoBack_Click">
                        <Button.Style>
                            <!-- Simple hover effect for the text link -->
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}" x:Name="txt"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="txt" Property="Foreground" Value="#111111"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </ScrollViewer>
</local:UserControlBase>
