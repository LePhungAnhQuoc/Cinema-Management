<UserControl x:Class="AnhQuoc_WPF_C1_B1.UserControls.Admin.ucMovieInformation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnhQuoc_WPF_C1_B1.UserControls.Admin"
             xmlns:converter="clr-namespace:AnhQuoc_WPF_C1_B1.Converters"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converter:ImageConverter x:Key="imageConverter" />
        <SolidColorBrush x:Key="LabelColor" Color="#666666" />
        <SolidColorBrush x:Key="TextBlockColor" Color="#808080" />

        <SolidColorBrush x:Key="TextPurple" Color="#7A52AA"/>
        <SolidColorBrush x:Key="LinkPurple" Color="#8F62CD"/>
        <SolidColorBrush x:Key="DarkPurple" Color="#3D2955"/>
        <SolidColorBrush x:Key="HeaderGray" Color="#EFEBEF"/>
        <SolidColorBrush x:Key="DividerGray" Color="#E5E5E5"/>

        <Style TargetType="Button" x:Key="TimeScheduleButton">
            <Setter Property="Background" Value="#F3F2F1"/>
            <Setter Property="Foreground" Value="#201F1E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E1DFDD"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                                            CornerRadius="6"
                                                                                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Hover & Press Effects -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource LinkPurple}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="{StaticResource LinkPurple}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccordionToggleStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="HeaderBorder" Background="Transparent" Padding="10" BorderBrush="{StaticResource DividerGray}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Content="{Binding Number, RelativeSource={RelativeSource AncestorType=Expander}}" VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" Content="{Binding Header, RelativeSource={RelativeSource AncestorType=Expander}}" VerticalAlignment="Center"/>

                                <Border Grid.Column="2" x:Name="ButtonBorder" Width="30" Height="30" CornerRadius="8" Background="{StaticResource DarkPurple}">
                                    <TextBlock x:Name="ButtonText" Text="+" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource HeaderGray}"/>
                                <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="ButtonText" Property="Text" Value="—"/>
                                <Setter TargetName="ButtonText" Property="FontSize" Value="14"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#FAFAFA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" SourceName="ButtonBorder" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource TextPurple}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomExpanderStyle" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition x:Name="ContentRow" Height="0"/>
                            </Grid.RowDefinitions>

                            <ToggleButton IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Style="{StaticResource AccordionToggleStyle}" />

                            <Border x:Name="ExpandedContent" Grid.Row="1" Visibility="Collapsed" Background="Transparent" Padding="30,0,30,0">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentRow" Property="Height" Value="*"/>
                                <Setter TargetName="ExpandedContent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DownloadButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DarkPurple}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="25,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource TextPurple}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Modernized Main Structure Concept -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <!-- Poster -->
            <ColumnDefinition Width="*"/>
            <!-- Content -->
        </Grid.ColumnDefinitions>

        <!-- Movie Poster with modern rounded corners -->
        <Border Width="300" Grid.Column="0" CornerRadius="8" Effect="{StaticResource DropShadowStyle1}" Margin="0,0,24,0">
            <Image Source="{Binding Movie.UrlImage}" Stretch="Uniform"/>
        </Border>


        <!-- Details Container -->
        <ScrollViewer Grid.Column="1" Margin="20">
            <StackPanel>
                <TextBlock Text="{Binding Movie.Name}" 
                        TextWrapping="Wrap"
                        FontSize="32" FontWeight="Bold" Foreground="#111111"/>

                <!-- Metadata Grid without harsh lines -->
                <UniformGrid Columns="2" Rows="2" Margin="0,8">
                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Rating:" FontWeight="SemiBold" Width="100"/>
                        <!-- Badge Style -->
                        <WrapPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBlock TextWrapping="Wrap"
                                        Foreground="#0288D1" FontWeight="Bold">
                            <Run Text="{Binding Movie.Rated.Id}" />
                            </TextBlock>
                            <Grid Margin="5 0 0 0">
                                <TextBlock Name="txtRatedDetailHyperlink">
                                <Hyperlink Click="RatedDetail_Click">
                                    (More details)
                                </Hyperlink>
                                </TextBlock>
                                <TextBlock Name="txtRatedDetail"
                                            Visibility="Collapsed"
                                            TextWrapping="Wrap"
                                            Text="{Binding Movie.Rated.Detail, StringFormat='({0})'}"/>
                            </Grid>
                        </WrapPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="10,8">
                        <TextBlock Text="Genres:" FontWeight="SemiBold" Width="100"/>
                        <Border Background="#EFEBE9" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="{Binding AllGenres}" Foreground="#4E342E"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <TextBlock Text="Running time:" FontWeight="SemiBold" Width="100"/>
                        <TextBlock Text="{Binding Movie.RunningTime, StringFormat='{}{0} minutes'}" Foreground="#555555"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="10,8">
                        <TextBlock Text="Release date:" FontWeight="SemiBold" Width="100"/>
                        <TextBlock Text="{Binding Movie.ReleaseDate, StringFormat='{}{0:d}'}" Foreground="#555555"/>
                    </StackPanel>
                </UniformGrid>

                <Separator Background="#EEEEEE" Height="1"/>

                <!-- Description Section -->
                <StackPanel>
                    <TextBlock Text="Description" 
                            Margin="0 10 0 15"
                            FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Movie.Description}" TextWrapping="Wrap" LineHeight="20" Foreground="#333333"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Movie schedules" 
                                   Margin="0 10 0 15"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <Button Name="btnAddNewSchedule"
                                Grid.Column="1"
                                Padding="10"
                                VerticalAlignment="Center"
                                Click="btnAddNewSchedule_Click"
                                Content="Add new schedule"
                                Style="{StaticResource AddButtonStyle}"/>

                    </Grid>
                    <Grid Margin="0 0 0 20">
                        <ListBox x:Name="lstMovieScheduleControl"
                                 ItemsSource="{Binding CinemaTypeSchedulesCollection}"
                                 SelectedItem="{Binding CurrentItem, Mode=TwoWay}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CinemaTypeSchedulesCollection.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Expander Expanded="Expander_Expanded"
                                              Style="{StaticResource CustomExpanderStyle}">
                                        <Expander.Header>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding CinemaType}"
                                                           VerticalAlignment="Center"
                                                           FontSize="18" FontWeight="Bold" Foreground="Black"/>
                                                <Button Name="btnAddNewCinema"
                                                        Grid.Column="1"
                                                        Click="btnAddNewCinema_Click"
                                                        Content="Add new cinema"
                                                        Style="{StaticResource AddButtonStyle}"
                                                        Padding="10 5"
                                                        VerticalAlignment="Stretch"
                                                        Margin="0 0 10 0"/>
                                            </Grid>
                                        </Expander.Header>
                                        <Expander.Tag>
                                            <TextBlock Text="01" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPurple}"/>
                                        </Expander.Tag>

                                        <ItemsControl ItemsSource="{Binding CinemaSchedules}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Expander Style="{StaticResource CustomExpanderStyle}">
                                                        <Expander.Header>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Cinema.Name}" FontSize="18" FontWeight="Bold" Foreground="Black"/>
                                                                <Grid Grid.Column="1"
                                                                      VerticalAlignment="Stretch"
                                                                      Margin="0 0 10 0">
                                                                    <Button Click="btnAddNewDate_Click"
                                                                            Content="Add new date"
                                                                            Style="{StaticResource AddButtonStyle}"
                                                                            Padding="10 5"/>
                                                                    <DatePicker Style="{StaticResource datePicker}"
                                                                                Padding="10 5"
                                                                                SelectedDateChanged="DatePicker_SelectedDateChanged"
                                                                                Visibility="Collapsed"/>
                                                                </Grid>
                                                            </Grid>
                                                        </Expander.Header>
                                                        <Expander.Tag>
                                                            <TextBlock Text="01" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPurple}"/>
                                                        </Expander.Tag>
                                                        <ItemsControl ItemsSource="{Binding DatesSchedule}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Margin="0,20,0,15">
                                                                        <!-- Modern Date Header -->
                                                                        <Grid Margin="0,0,0,8">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <!-- Simple calendar icon or text block layout -->
                                                                            <TextBlock Text="{Binding Date, StringFormat='{}{0:dddd, MMMM dd, yyyy}'}" 
                                                            FontSize="14" FontWeight="SemiBold" Foreground="#666666"/>

                                                                            <Grid Grid.Column="1"
                                                                                  VerticalAlignment="Stretch"
                                                                                  Margin="0 0 20 0">
                                                                                <Button Click="btnAddNewTime_Click"
                                                                                        Content="Add new time"
                                                                                        Style="{StaticResource AddButtonStyle}"
                                                                                        Padding="10 5"/>
                                                                                <syncfusion:SfTimePicker HorizontalContentAlignment="Center"
                                                                                                         Padding="10 5"
                                                                                                         Visibility="Collapsed"
                                                                                                         FormatString="HH\:mm"
                                                                                                         SelectorFormatString="HH\:mm"
                                                                                                         ValueChanged="selectTime_ValueChanged"/>
                                                                            </Grid>

                                                                        </Grid>

                                                                        <!-- Horizontal wrap layout for Showtimes -->
                                                                        <ItemsControl ItemsSource="{Binding TimeSchedules}">
                                                                            <ItemsControl.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                    <!-- Automatically wraps time blocks horizontally -->
                                                                                    <WrapPanel Orientation="Horizontal" />
                                                                                </ItemsPanelTemplate>
                                                                            </ItemsControl.ItemsPanel>
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <!-- Modern Clickable Time Block (Chip Style) -->
                                                                                    <Button Content="{Binding Time}" 
                                                                                            Margin="0,0,8,8"
                                                                                            Padding="14,8,14,8"
                                                                                            Cursor="Hand"
                                                                                            Style="{StaticResource TimeScheduleButton}"
                                                                                            Click="btnTimeSchedule_Click"/>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Expander>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Name="txtNoMovieSchedule" Text="No movie schedule yet" LineHeight="20" Foreground="#333333">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CinemaTypeSchedulesCollection.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <TextBlock Text="Watch movie trailer" 
                                Margin="0 10 0 15"
                                FontSize="16" FontWeight="SemiBold"/>

                    <Grid>
                        <Grid Name="PlayerGrid">
                            <MediaElement Name="MyMediaElement" 
                                        Source="{Binding MovieUrlTrailer}" 
                                        LoadedBehavior="Manual" 
                                        UnloadedBehavior="Stop"
                                        Stretch="Uniform"
                                        MediaOpened="MyMediaElement_MediaOpened"
                                        MediaFailed="MyMediaElement_MediaFailed"/>

                            <Border VerticalAlignment="Bottom" 
                                Background="#CC1A1A1A" 
                                CornerRadius="8" 
                                Margin="15" 
                                Padding="10,5,10,5"
                                Effect="{StaticResource DropShadowStyle1}">

                                <Border.Resources>
                                    <DropShadowEffect x:Key="MyDropShadowEffect" BlurRadius="15" Opacity="0.3" Direction="270"/>
                                </Border.Resources>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,5">
                                        <Slider Name="TimelineSlider" 
                                            Minimum="0" 
                                            Maximum="1" 
                                            Value="0"
                                            PreviewMouseLeftButtonDown="TimelineSlider_PreviewMouseLeftButtonDown"
                                            PreviewMouseLeftButtonUp="TimelineSlider_PreviewMouseLeftButtonUp"
                                            ValueChanged="TimelineSlider_ValueChanged"
                                            Background="#555" Foreground="#E50914"/>
                                    </Grid>

                                    <Grid Grid.Row="1" Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Button Name="BtnPlayPause" Content="▶" Width="35" Height="30" Click="BtnPlayPause_Click"
                            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                                            <Button Name="BtnStop" Content="◼" Width="35" Height="30" Click="BtnStop_Click"
                            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" Cursor="Hand" Margin="5,0,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <TextBlock Name="TxtCurrentTime" Text="00:00" Foreground="White" FontSize="12"/>
                                            <TextBlock Text=" / " Foreground="#888" FontSize="12"/>
                                            <TextBlock Name="TxtTotalTime" Text="00:00" Foreground="#888" FontSize="12"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Name="BtnMute" Content="🔊" Width="30" Height="30" Click="BtnMute_Click"
                            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                                            <Slider Name="VolumeSlider" Width="80" VerticalAlignment="Center" Margin="5,0,0,0"
                            Minimum="0" Maximum="1" Value="0.5" ValueChanged="VolumeSlider_ValueChanged"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="txtNoMovieTrailer"
                                    Text="The movie trailer is not yet available."
                                    Visibility="Collapsed" />
                    </Grid>
                </StackPanel>

                <!-- Footer section -->
                <StackPanel Orientation="Horizontal"
                            Margin="0 30 0 0"
                            HorizontalAlignment="Center">
                    <Button x:Name="btnConfirm"
                            Style="{StaticResource ConfirmButtonStyle}"
                            Click="btnConfirm_Click"/>
                    <Button x:Name="btnCancel"
                            Style="{StaticResource CancelButtonStyle}"
                            Click="btnCancel_Click"
                            Margin="10 0 0 0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
