<Window x:Class="AnhQuoc_WPF_C1_B1.Views.frmSelectMovie"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnhQuoc_WPF_C1_B1"
        mc:Ignorable="d"
        Title="frmSelectMovie" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <local:ucMovieTable x:Name="ucMovieTable" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="btnSelect" Content="Select" Style="{StaticResource ConfirmButtonStyle}" Click="btnSelect_Click" />
            <Button x:Name="btnCancel" Content="Cancel" Style="{StaticResource CancelButtonStyle}" Margin="10 0 0 0" />
        </StackPanel>
    </Grid>
</Window>
