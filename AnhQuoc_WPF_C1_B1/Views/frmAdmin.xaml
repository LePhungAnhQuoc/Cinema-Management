<Window x:Class="AnhQuoc_WPF_C1_B1.frmAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnhQuoc_WPF_C1_B1"
        xmlns:template="clr-namespace:AnhQuoc_WPF_C1_B1.UserControls.Templates"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Title="Admin view" Height="600" Width="1300"
        Closed="Window_Closed">
    <Grid Name="gdAdmin">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Height="70">
                <Image Source="{Binding AccountImage}"
                       Width="30" Height="30" 
                       Margin="10,0,5,0" 
                       HorizontalAlignment="Left" 
                       Stretch="UniformToFill">
                    <Image.Clip>
                        <EllipseGeometry Center="15,15" RadiusX="15" RadiusY="15" />
                    </Image.Clip>
                </Image>
                <Label Name="lbAdminName" 
                           VerticalContentAlignment="Center" 
                           HorizontalContentAlignment="Left" 
                           Padding="10 0"
                           FontSize="20"
                           Margin="0 10"
                           FontWeight="SemiBold"
                           Content="{Binding Account.Username}"
                           Foreground="Black"></Label>
            </StackPanel>
            <TreeView Background="White"
                      Grid.RowSpan="2"
                      BorderThickness="0"
                      Width="250">
                <TreeView.ItemContainerStyle>
                    <Style BasedOn="{StaticResource TreeViewItemStyle}" TargetType="{x:Type TreeViewItem}">
                        <Setter Property="FontWeight" Value="Normal" />
                        <Setter Property="Padding" Value="20" />
                        <Setter Property="Foreground" Value="Black" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Background" Value="Gray" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeViewItem Name="tvAccount" Header="Account" MouseLeftButtonUp="tvAccount_MouseLeftButtonUp" local:TreeViewExtensions.IconSource="/bin/Debug/Assets/account.png"/>
                <TreeViewItem Name="tvMovie" Header="Movie" MouseLeftButtonUp="tvMovie_MouseLeftButtonUp" local:TreeViewExtensions.IconSource="/bin/Debug/Assets/movie.png"/>
                <TreeViewItem Name="tvMovieSchedule" Header="Movie Schedule" MouseLeftButtonUp="tvMovieSchedule_MouseLeftButtonUp" local:TreeViewExtensions.IconSource="/bin/Debug/Assets/movie-schedule.png"/>
                <TreeViewItem Name="tvStatistical" Header="Statistical" MouseLeftButtonUp="tvStatistical_MouseLeftButtonUp" local:TreeViewExtensions.IconSource="/bin/Debug/Assets/Statistical.png"/>
                <TreeViewItem Name="tvLogOut" Header="Log out" MouseLeftButtonUp="tvLogOut_MouseLeftButtonUp" local:TreeViewExtensions.IconSource="/bin/Debug/Assets/Others/logout.png"/>
            </TreeView>
        </StackPanel>

        <Grid Grid.Column="1"
              Name="stkView"
              Margin="30 0 0 0">
            <StackPanel>
                <Grid HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="0 50 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <Image Source="/bin/Debug/Assets/Others/CinemaIcon.png" Width="60" Height="60" />
                    <StackPanel Grid.Column="1"
                                Orientation="Vertical">
                        <Label Grid.Column="1"
                               VerticalContentAlignment="Center"
                               HorizontalContentAlignment="Left"
                               Padding="10 0 0 0"
                               FontSize="20"
                               Foreground="Black"
                               Content="Welcome back to," />
                        <Label Grid.Column="1"
                               VerticalContentAlignment="Center"
                               HorizontalContentAlignment="Left"
                               Padding="10 0 0 0"
                               FontSize="30"
                               Foreground="Black"
                               Content="{Binding Account.Username}" />
                    </StackPanel>
                </Grid>
                <WrapPanel Margin="0 30 0 0">
                    <template:ucDashboardCard Title="Total accounts"
                                              Value="{Binding TotalAccounts}"
                                              IconData="{StaticResource usersIconData}"
                                              OuterBackground="#ff3b55"
                                              Margin="10"/>
                    <template:ucDashboardCard Title="Total movies" 
                                              Value="{Binding TotalMovies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                              IconData="{StaticResource movieIconData}"
                                              Margin="10"/>
                    <template:ucDashboardCard Title="Total orders"
                                              Value="{Binding TotalOrders, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IconData="{StaticResource orderIconData}"
                                              OuterBackground="#5846FF"
                                              Margin="10" />
                    <template:ucDashboardCard Title="Total order details"
                                              Value="{Binding TotalOrderDetails, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IconData="{StaticResource orderDetailData}"
                                              OuterBackground="#1955c2"
                                              Margin="10" />
                </WrapPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
