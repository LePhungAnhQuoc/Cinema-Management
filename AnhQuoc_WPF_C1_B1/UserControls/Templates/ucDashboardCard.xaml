<UserControl x:Class="AnhQuoc_WPF_C1_B1.UserControls.Templates.ucDashboardCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnhQuoc_WPF_C1_B1.UserControls.Templates"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Width="300">
        <Border CornerRadius="75" 
            Background="{Binding OuterBackground, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Padding="10">

            <Border Background="{Binding InnerBackground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CornerRadius="75"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Margin="10,0,0,0">
                        <Ellipse Fill="#4DFFFFFF" 
                             Margin="8,8,0,0"
                             Height="100" Width="100"/>

                        <Ellipse Fill="{Binding InnerBackground, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                             StrokeThickness="1" 
                             Stroke="White"
                             Height="100" Width="100"/>

                        <Path Data="{Binding IconData, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          Fill="White" 
                          Stretch="Uniform" 
                          Width="40" Height="40"/>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,15,0">
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                               Foreground="White"
                               FontSize="20" 
                               TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                               Foreground="White"
                               FontSize="25" 
                               FontWeight="Bold" 
                               Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
